<?xml version="1.0" ?>
<labwc_config>
    <theme>
        <name>BreezeDark</name>
        <cornerRadius>7</cornerRadius>
        <font name="LigaMonaco Nerd Font" size="12" />
    </theme>
    <placement>
        <policy>cascade</policy>
        <cascadeOffset x="40" y="30"/>
    </placement>
    <resize>
        <popupShow>Never</popupShow>
        <drawContents>no</drawContents>
        <minimumArea>8</minimumArea>
    </resize>
    <focus>
        <followMouse>yes</followMouse>
        <followMouseRequiresMovement>yes</followMouseRequiresMovement>
        <raiseOnFocus>no</raiseOnFocus>
    </focus>
    <desktops number="4" />
    <keyboard>
        <default />
        <!-- various -->
        <keybind key="A-Return"><action name="Execute" command="foot"/></keybind>
        <keybind key="A-r"><action name="Execute" command="bash -c 'kill -s SIGHUP $(pidof labwc)'"/></keybind>
        <keybind key="A-p"><action name="Execute" command="wmenu-run -f 'LigaMonaco Nerd Font 12' -N 000000 -n FFFFFF -S 143348 -s FFFFFF -b"/></keybind>
        <keybind key="A-q"><action name="Close" /></keybind>
        <keybind key="A-f"><action name="ToggleMaximize" /></keybind>
        <keybind key="A-Tab"><action name="NextWindow" /></keybind>

        <!-- workspaces -->
        <keybind key="A-1"><action name="GoToDesktop" to="1" /></keybind>
        <keybind key="A-2"><action name="GoToDesktop" to="2" /></keybind>
        <keybind key="A-3"><action name="GoToDesktop" to="3" /></keybind>
        <keybind key="A-4"><action name="GoToDesktop" to="4" /></keybind>

        <!-- audio -->
        <keybind key="A-u"><action name="Execute" command="swayosd-client --output-volume lower" /></keybind>
        <keybind key="A-i"><action name="Execute" command="swayosd-client --output-volume raise" /></keybind>
        <keybind key="A-m"><action name="Execute" command="swayosd-client --output-volume mute-toggle" /></keybind>
        <keybind key="A-S-m"><action name="Execute" command="swayosd-client --input-volume mute-toggle" /></keybind>
        <keybind key="XF86AudioLowerVolume"><action name="Execute" command="swayosd-client --output-volume lower" /></keybind>
        <keybind key="XF86AudioRaiseVolume"><action name="Execute" command="swayosd-client --output-volume raise" /></keybind>
        <keybind key="XF86AudioMute"><action name="Execute" command="swayosd-client --output-volume mute-toggle" /></keybind>
        <keybind key="XF86AudioMicMute"><action name="Execute" command="swayosd-client --input-volme mute-toggle" /></keybind>

        <!-- brightness -->
        <keybind key="XF86MonBrightnessUp"><action name="Execute" command="brightnessctl --class=backlight set +10%"/></keybind>
        <keybind key="XF86MonBrightnessDown"><action name="Execute" command="brightnessctl --class=backlight set 10%-"/></keybind>
    </keyboard>
</labwc_config>
