# Backgrounds
set default-bg          "#f6f4ef"
set statusbar-bg        "#ece8e1"
set inputbar-bg         "#ece8e1"
set notification-bg     "#ece8e1"
set recolor-lightcolor  "#f6f4ef"

# Text / foreground (high contrast)
set default-fg          "#1f2328"
set statusbar-fg        "#1f2328"
set inputbar-fg         "#1f2328"
set notification-fg     "#1f2328"
set recolor-darkcolor   "#1f2328"

# Selection & highlights
set highlight-color     "#ffd866"
set highlight-fg        "#1f2328"

# Completion menu
set completion-bg       "#ece8e1"
set completion-fg       "#3b4046"
set completion-group-bg "#cdd6dd"
set completion-group-fg "#1f2328"
set completion-highlight-bg "#cdd6dd"
set completion-highlight-fg "#1f2328"

# Index (table of contents)
set index-bg            "#f6f4ef"
set index-fg            "#3b4046"
set index-active-bg     "#cdd6dd"
set index-active-fg     "#1f2328"

# Status notifications
set notification-error-bg   "#f38ba8"
set notification-error-fg   "#1f2328"
set notification-warning-bg "#f9e2af"
set notification-warning-fg "#1f2328"

# Recolor settings for PDFs
set recolor true
set recolor-keephue true

# Minimal UI
set guioptions ""

# Font
set font "LigaMonaco Nerd Font 12"

